{
    "name": "orange/cache",
    "description": "Cache adapters covering files, Redis, Memcached, include-based, and dummy backends.",
    "type": "library",
    "homepage": "https://github.com/ProjectOrangeBox/cache",
    "license": "MIT",
    "authors": [
        {
            "name": "Don Myers",
            "email": "donmyers@me.com"
        }
    ],
    "support": {
        "issues": "https://github.com/ProjectOrangeBox/cache/issues",
        "source": "https://github.com/ProjectOrangeBox/cache"
    },
    "require": {
        "php": ">=8.4",
        "orange/framework": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.2"
    },
    "autoload": {
        "psr-4": {
            "peels\\cache\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
